# =========================
# Environment configuration
# =========================
# Copy this file to ".env" and fill in the values below.
# Required values are marked with (REQUIRED).

# Local development: keep this as "development".
# Deployment/production: set this to "production" via your hosting dashboard / server environment variables.
NODE_ENV=development
TRUST_PROXY=false
SESSION_COOKIE_SECURE=false



# --- Configure below ---

# Port for the Express server (default: 3000)
PORT=3000


# Database (REQUIRED)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=sportmeet_db
DB_PASSWORD=
DB_PORT=5432
DATABASE_URL=postgres://postgres:DB_PASSWORD@localhost:5432/sportmeet_db

# Sessions/Auth (REQUIRED)
SESSION_SECRET=

# Geocoding (optional)
GEOCODING_PROVIDER=nominatim
GEOCODING_USER_AGENT=sportmeet/0.1 (tony.n@gso.schule.koeln)


# Mail Service
BREVO_API_KEY=
MAIL_FROM_NAME=Sportmeet
MAIL_FROM_ADDRESS=tony.n@gso.schule.koeln
APP_BASE_URL=http://localhost:3000

# Event reminder scheduler (optional)
EVENT_REMINDER_ENABLED=true
EVENT_REMINDER_INTERVAL_MINUTES=15
EVENT_REMINDER_LEAD_MINUTES=1440
EVENT_REMINDER_WINDOW_MINUTES=15
