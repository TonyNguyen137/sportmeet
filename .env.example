# =========================
# Environment configuration
# =========================
# Copy this file to ".env" and fill in the values below.
# Required values are marked with (REQUIRED).

# Local development: keep this as "development".
# Deployment/production: set this to "production" via your hosting dashboard / server environment variables.
NODE_ENV=development
TRUST_PROXY=false
SESSION_COOKIE_SECURE=false



# --- Configure below ---

# Port for the Express server (default: 3000)
PORT=


# Database (REQUIRED)
DB_USER=
DB_HOST=
DB_NAME=
DB_PASSWORD=
DB_PORT=
DATABASE_URL=

# Sessions/Auth (REQUIRED)
SESSION_SECRET=

# Geocoding (optional)
GEOCODING_PROVIDER=nominatim
GEOCODING_USER_AGENT=sportmeet/0.1 (admin@example.com)


# Mail Service
BREVO_API_KEY=
MAIL_FROM_NAME=
MAIL_FROM_ADDRESS=
APP_BASE_URL=

# Event reminder scheduler (optional)
EVENT_REMINDER_ENABLED=true
EVENT_REMINDER_INTERVAL_MINUTES=15
EVENT_REMINDER_LEAD_MINUTES=1440
EVENT_REMINDER_WINDOW_MINUTES=15
