<%- include("../parts/header") %>

<main class="grid px-[12px] py-[32px]">
	<div class="login rounded-default w-full max-w-[650px] place-self-center bg-white p-[16px] text-center sm:p-[32px]">
		<div class="bg-accent-blue mx-auto mb-4 flex h-[64px] w-[64px] items-center justify-center rounded-full">
			<svg width="32" height="32" aria-hidden="true" class="text-white">
				<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#user' %>"></use>
			</svg>
		</div>
		<h1 class="text-h1 leading-none font-bold text-black">Konto erstellen</h1>
		<p class="mt-4">Registrieren Sie sich für ein neues Konto</p>

		<form class="login__form text-neutral mt-5 text-start" data-register-form action="/register" method="POST">
			<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
			<div
				class="<%= loginErrors && loginErrors.length ? 'block' : 'hidden' %> focus:sol focus:outline-s mt-4 mb-6 rounded-lg border border-amber-200 bg-amber-50 p-4 focus:outline-2 focus:outline-offset-[0.15lh] focus:outline-amber-700 focus:outline-solid"
				data-error-container
				tabindex="-1">
				<div class="flex items-start gap-2">
					<svg width="16" height="16" aria-hidden="true" class="lh-[1em] mt-0.5 flex-shrink-0 text-amber-600">
						<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#alert' %>"></use>
					</svg>
					<div class="text-start">
						<p class="text-sm font-semibold text-amber-800" data-error-title><%= loginErrorTitle %></p>
						<ul data-error-list class="list-disc ps-[0.85em]">
							<% if (loginErrors && loginErrors.length) { %> <% loginErrors.forEach((error) => { %>
							<li class="text-sm text-amber-700"><%= error %></li>
							<% }) %> <% } %>
						</ul>
					</div>
				</div>
			</div>
			<div class="login__group">
				<label class="text-sm text-black" for="firstName">Vorname</label>
				<div
					class="focus-within:outline-accent-blue flex items-center gap-[12px] rounded-sm px-[16px] py-[12px] outline outline-neutral-100 focus-within:outline focus-within:outline-[2px]">
					<svg class="text-neutral-400" width="20" height="20" aria-hidden="true">
						<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#id-card' %>"></use>
					</svg>

					<input
						class="grow placeholder:text-neutral-400 focus-visible:outline-0"
						type="text"
						id="firstName"
						name="firstName"
						value="<%= (loginValues && loginValues.firstName) || '' %>"
						placeholder="Ihr Vorname"
						required />
				</div>
			</div>

			<div class="login__group mt-4">
				<label class="text-sm text-black" for="lastName">Nachname</label>
				<div
					class="focus-within:outline-accent-blue flex items-center gap-[12px] rounded-sm px-[16px] py-[12px] outline outline-neutral-100 focus-within:outline focus-within:outline-[2px]">
					<svg class="text-neutral-400" width="20" height="20" aria-hidden="true">
						<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#id-card' %>"></use>
					</svg>

					<input
						class="grow placeholder:text-neutral-400 focus-visible:outline-0"
						type="text"
						id="lastName"
						name="lastName"
						value="<%= (loginValues && loginValues.lastName) || '' %>"
						placeholder="Ihr Nachname"
						required />
				</div>
			</div>

			<div class="login__group mt-4">
				<label class="text-sm text-black" for="email">E-Mail-Adresse</label>
				<div
					class="focus-within:outline-accent-blue mt-1 flex items-center gap-[12px] rounded-sm px-[16px] py-[12px] outline outline-neutral-100 focus-within:outline focus-within:outline-[2px]">
					<svg class="text-neutral-400" width="20" height="20" aria-hidden="true">
						<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#email' %>"></use>
					</svg>

					<input
						class="grow placeholder:text-neutral-400 focus-visible:outline-0"
						type="email"
						id="email"
						name="email"
						value="<%= (loginValues && loginValues.email) || '' %>"
						placeholder="ihre@email.com"
						required />
				</div>
			</div>

			<div class="login__group mt-4">
				<label class="text-sm text-black" for="password">
					<span>Passwort</span>
					<div class="sr-only">
						<span>Ihr Passwort muss enthalten</span>
						<ul>
							<li>Mindestens 8 Zeichen</li>
							<li>Eine Zahl</li>
							<li>Einen Großbuchstaben</li>
						</ul>
					</div>
				</label>
				<div
					class="focus-within:outline-accent-blue mt-1 flex items-center gap-[12px] rounded-sm px-[16px] py-[12px] outline outline-neutral-100 focus-within:outline focus-within:outline-[2px]">
					<svg class="text-neutral-400" width="20" height="20" aria-hidden="true">
						<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#lock' %>"></use>
					</svg>

					<input
						class="grow placeholder:text-neutral-400 focus-visible:outline-0"
						type="password"
						id="password"
						name="password"
						data-password-input
						required />
					<button
						type="button"
						class="btn btn--toggle-visibility grid cursor-pointer [grid-template-areas:'stack']"
						aria-label="Passwort anzeigen">
						<svg class="eye text-neutral-400 [grid-area:stack]" width="20" height="20" aria-hidden="true">
							<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#eye' %>"></use>
						</svg>
						<svg class="eye-off hidden text-neutral-400 [grid-area:stack]" width="20" height="20" aria-hidden="true">
							<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#eye-off' %>"></use>
						</svg>
					</button>
				</div>
			</div>

			<div class="mt-3 space-y-1" data-requirements-container>
				<p class="text-xs font-medium text-gray-600">Ihr Passwort muss enthalten:</p>
				<ul class="text-xsm space-y-1 text-xs text-gray-600">
					<li class="flex items-center gap-2" data-requirement-8chars>
						<span class="flex h-4 w-4 items-center justify-center rounded-full bg-gray-100" data-requirement-icon>○</span>Mindestens 8
						Zeichen
					</li>
					<li class="flex items-center gap-2" data-requirement-uppercase>
						<span class="flex h-4 w-4 items-center justify-center rounded-full bg-gray-100" data-requirement-icon>○</span>Einen
						Großbuchstaben
					</li>
					<li class="flex items-center gap-2" data-requirement-number>
						<span class="flex h-4 w-4 items-center justify-center rounded-full bg-gray-100" data-requirement-icon>○</span>Eine Zahl
					</li>
				</ul>
			</div>

			<div class="login__group mt-4">
				<label class="text-sm text-black" for="passwordConfirm">Passwort bestätigen</label>
				<div
					class="focus-within:outline-accent-blue mt-1 flex items-center gap-[12px] rounded-sm px-[16px] py-[12px] outline outline-neutral-100 focus-within:outline focus-within:outline-[2px]">
					<svg class="text-neutral-400" width="20" height="20" aria-hidden="true">
						<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#lock' %>"></use>
					</svg>

					<input
						class="grow placeholder:text-neutral-400 focus-visible:outline-0"
						type="password"
						id="passwordConfirm"
						name="passwordConfirm"
						data-field-label="Passwort-Bestätigung"
						required />
					<button
						type="button"
						class="btn btn--toggle-visibility grid cursor-pointer [grid-template-areas:'stack']"
						aria-label="Passwort anzeigen">
						<svg class="eye text-neutral-400 [grid-area:stack]" width="20" height="20" aria-hidden="true">
							<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#eye' %>"></use>
						</svg>
						<svg class="eye-off hidden text-neutral-400 [grid-area:stack]" width="20" height="20" aria-hidden="true">
							<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#eye-off' %>"></use>
						</svg>
					</button>
				</div>
			</div>
			<button
				type="submit"
				class="bg-accent-blue hover:bg-accent-dark-blue mt-4 w-full cursor-pointer rounded-sm p-[12px] text-white transition-colors duration-200 ease-in-out">
				Registrieren
			</button>
			<p class="mt-4 text-center">
				Bereits ein Konto?
				<a href="/" class="text-accent-blue hover:underline">zur Anmeldung</a>
			</p>
		</form>
	</div>
</main>

<%- include("../parts/footer") %>
