<%- include("../parts/header") %>

<main class="grid grid-cols-[minmax(300px,570px)] place-content-center p-[16px] py-[32px]">
	<div class="rounded-default bg-white p-[16px] text-center sm:p-[32px]">
		<div class="bg-accent-blue mx-auto mb-4 flex h-[64px] w-[64px] items-center justify-center rounded-full">
			<svg width="32" height="32" aria-hidden="true" class="text-white">
				<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#lock' %>"></use>
			</svg>
		</div>
		<h1 class="text-h1 leading-none font-bold text-black">Neues Passwort setzen</h1>
		<p class="mt-4">Vergeben Sie ein neues Passwort für Ihr Konto</p>

		<div class="<%= resetTokenError ? 'block' : 'hidden' %> mt-4 mb-6 rounded-lg border border-amber-200 bg-amber-50 p-3" tabindex="-1">
			<p class="text-sm font-semibold text-amber-800">Link ungültig:</p>
			<ul class="mt-2 list-disc ps-[0.85em]">
				<li class="text-sm text-amber-700"><%= resetTokenError %></li>
			</ul>
		</div>

		<form data-reset-password-form class="login__form text-neutral mt-5 text-start" action="/reset-password" method="POST">
			<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
			<input type="hidden" name="token" value="<%= (resetValues && resetValues.token) || '' %>" />

			<div
				class="<%= resetErrors && resetErrors.length ? 'block' : 'hidden' %> mt-4 mb-6 rounded-lg border border-amber-200 bg-amber-50 p-3"
				data-error-container
				tabindex="-1">
				<p class="text-sm font-semibold text-amber-800" data-error-title>
					<%= resetErrorTitle || 'Fehlende Angaben, bitte füllen Sie die gelisteten Felder aus:' %>
				</p>
				<ul class="mt-2 list-disc ps-[0.85em]" data-error-list>
					<% if (resetErrors && resetErrors.length) { %> <% resetErrors.forEach((error) => { %>
					<li class="text-sm text-amber-700"><%= error %></li>
					<% }) %> <% } %>
				</ul>
			</div>

			<div class="login__group mt-4">
				<label class="text-sm text-black" for="password">Neues Passwort</label>
				<div
					class="focus-within:outline-accent-blue mt-1 flex items-center gap-[12px] rounded-sm px-[16px] py-[12px] outline outline-neutral-100 focus-within:outline focus-within:outline-[2px]">
					<svg class="text-neutral-400" width="20" height="20" aria-hidden="true">
						<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#lock' %>"></use>
					</svg>
					<input
						class="grow placeholder:text-neutral-400 focus-visible:outline-0"
						type="password"
						id="password"
						name="password"
						data-password-input
						data-field-label="Passwort"
						required />
					<button
						data-password-toggle
						type="button"
						class="btn btn--toggle-visibility grid cursor-pointer [grid-template-areas:'stack']"
						aria-label="Passwort anzeigen">
						<svg class="eye text-neutral-400 [grid-area:stack]" width="20" height="20" aria-hidden="true">
							<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#eye' %>"></use>
						</svg>
						<svg class="eye-off hidden text-neutral-400 [grid-area:stack]" width="20" height="20" aria-hidden="true">
							<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#eye-off' %>"></use>
						</svg>
					</button>
				</div>
			</div>

			<div class="mt-3 space-y-1" data-requirements-container>
				<p class="text-xs font-medium text-gray-600">Ihr Passwort muss enthalten:</p>
				<ul class="text-xsm space-y-1 text-xs text-gray-600">
					<li class="flex items-center gap-2" data-requirement-8chars>
						<span class="flex h-4 w-4 items-center justify-center rounded-full bg-gray-100" data-requirement-icon>○</span>Mindestens 8
						Zeichen
					</li>
					<li class="flex items-center gap-2" data-requirement-uppercase>
						<span class="flex h-4 w-4 items-center justify-center rounded-full bg-gray-100" data-requirement-icon>○</span>Einen
						Großbuchstaben
					</li>
					<li class="flex items-center gap-2" data-requirement-number>
						<span class="flex h-4 w-4 items-center justify-center rounded-full bg-gray-100" data-requirement-icon>○</span>Eine Zahl
					</li>
				</ul>
			</div>

			<div class="login__group mt-4">
				<label class="text-sm text-black" for="passwordConfirm">Passwort bestätigen</label>
				<div
					class="focus-within:outline-accent-blue mt-1 flex items-center gap-[12px] rounded-sm px-[16px] py-[12px] outline outline-neutral-100 focus-within:outline focus-within:outline-[2px]">
					<svg class="text-neutral-400" width="20" height="20" aria-hidden="true">
						<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#lock' %>"></use>
					</svg>
					<input
						class="grow placeholder:text-neutral-400 focus-visible:outline-0"
						type="password"
						id="passwordConfirm"
						name="passwordConfirm"
						data-field-label="Passwort-Bestätigung"
						required />
					<button
						data-password-toggle
						type="button"
						class="btn btn--toggle-visibility grid cursor-pointer [grid-template-areas:'stack']"
						aria-label="Passwort anzeigen">
						<svg class="eye text-neutral-400 [grid-area:stack]" width="20" height="20" aria-hidden="true">
							<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#eye' %>"></use>
						</svg>
						<svg class="eye-off hidden text-neutral-400 [grid-area:stack]" width="20" height="20" aria-hidden="true">
							<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#eye-off' %>"></use>
						</svg>
					</button>
				</div>
			</div>

			<% if (resetTokenValid) { %>
			<button
				type="submit"
				class="bg-accent-blue hover:bg-accent-dark-blue mt-4 w-full cursor-pointer rounded-sm p-[12px] text-white transition-colors duration-200 ease-in-out disabled:cursor-not-allowed disabled:opacity-60">
				Passwort speichern
			</button>
			<% } else { %>
			<button
				type="submit"
				disabled="disabled"
				class="bg-accent-blue hover:bg-accent-dark-blue mt-4 w-full cursor-not-allowed rounded-sm p-[12px] text-white opacity-60 transition-colors duration-200 ease-in-out disabled:cursor-not-allowed disabled:opacity-60">
				Passwort speichern
			</button>
			<% } %>

			<a href="/" class="text-accent-blue mt-4 inline-block text-center hover:underline"> Zurück zur Anmeldung </a>
		</form>
	</div>
</main>

<%- include("../parts/footer") %>
