<%- include("../parts/header", { variant: "user", activeDashboardPage: 'events' }) %>

<main>
	<div class="container mx-auto px-[12px] py-[32px]">
		<a
			href="<%= event.group_id ? `/groups/${event.group_id}` : '/me' %>"
			class="mb-4 inline-flex cursor-pointer items-center gap-2 text-sm font-semibold text-emerald-700 hover:text-emerald-800">
			<span aria-hidden="true"><-</span>
			zurück
		</a>

		<div class="overflow-auto rounded-sm bg-white shadow-sm">
			<div class="bg-emerald-600 p-4 text-white md:px-8 md:py-5">
				<h1 class="text-h1 font-bold"><%= event.title %></h1>
				<p><%= event.participant_count %> Teilnehmer</p>
			</div>

			<div class="space-y-4 p-4 md:px-8 md:py-5">
				<% if (event.is_participating) { %>
				<div class="flex items-start gap-2">
					<span class="rounded-sm bg-emerald-50 p-1">
						<svg class="text-emerald-700" aria-hidden="true" width="24" height="24">
							<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#check' %>"></use>
						</svg>
					</span>
					<div>
						<p class="text-sm text-gray-500">Status</p>
						<p class="font-medium text-gray-900">Du nimmst teil</p>
					</div>
				</div>
				<% } %> <% if (event.description) { %>
				<div class="flex items-start gap-2">
					<span class="rounded-sm bg-emerald-50 p-1">
						<svg class="text-emerald-700" aria-hidden="true" width="24" height="24">
							<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#text-quote' %>"></use>
						</svg>
					</span>
					<div>
						<p class="text-sm text-gray-500">Beschreibung</p>
						<p class="text-gray-900"><%= event.description %></p>
					</div>
				</div>
				<% } %>

				<div class="flex items-start gap-2">
					<span class="rounded-sm bg-emerald-50 p-1">
						<svg class="text-emerald-700" aria-hidden="true" width="24" height="24">
							<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#globe' %>"></use>
						</svg>
					</span>
					<div>
						<p class="text-sm text-gray-500">Adresse</p>
						<p class="text-gray-900">
							<%= event.location_name || `${event.street} ${event.house_number}, ${event.postal_code} ${event.city}` %>
						</p>
					</div>
				</div>

				<div class="flex items-start gap-2">
					<span class="rounded-sm bg-emerald-50 p-1">
						<svg class="text-emerald-700" aria-hidden="true" width="24" height="24">
							<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#admin' %>"></use>
						</svg>
					</span>
					<div>
						<p class="text-sm text-gray-500">Administrator</p>
						<p class="font-medium text-gray-900">
							<%= event.admin_first_name %> <%= event.admin_last_name %> <% if (event.is_admin) { %>
							<span class="ml-2 rounded-full bg-emerald-100 px-2 py-0.5 text-xs text-emerald-800">Du</span>
							<% } %>
						</p>
					</div>
				</div>
			</div>
		</div>

		<section class="mt-6 rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
			<div class="mb-4 flex flex-wrap items-baseline gap-2">
				<h3 class="text-lg font-semibold text-gray-900">Teilnehmer</h3>
				<span class="text-[1.1rem] text-gray-500"><%= event.participant_count %></span>
			</div>

			<div class="max-h-96 space-y-3 overflow-y-auto" data-event-participants-list>
				<% participants.forEach((participant) => { %> <% const initials = `${(participant.first_name ||
				'').charAt(0)}${(participant.last_name || '').charAt(0)}`.toUpperCase(); %>
				<div class="flex items-center gap-3 rounded-lg bg-gray-50 p-3 transition-colors hover:bg-gray-100">
					<div
						class="flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-emerald-400 to-cyan-500 text-sm font-semibold text-white">
						<%= initials %>
					</div>

					<div class="min-w-0 flex-1">
						<p class="truncate text-sm font-medium text-gray-900">
							<%= participant.first_name %> <%= participant.last_name %> <% if (participant.is_current_user) { %>
							<span class="ml-2 rounded-full bg-emerald-100 px-2 py-0.5 text-xs text-emerald-800">Du</span>
							<% } %>
						</p>
						<% if (participant.is_admin) { %>
						<span
							class="inline-flex items-center rounded-full border border-amber-200 bg-amber-50 px-2 py-0.5 text-xs font-semibold text-amber-800">
							Admin
						</span>
						<% } else { %>
						<p class="text-xs text-gray-500">Teilnehmer</p>
						<% } %>
					</div>

					<% if (event.is_admin && !event.is_expired && !participant.is_admin) { %>
					<button
						type="button"
						class="cursor-pointer rounded-sm border-none bg-red-100 p-2"
						aria-label="Teilnehmer entfernen"
						data-event-participant-kick
						data-kick-url="/events/<%= event.id %>/participants/<%= participant.id %>/remove"
						data-participant-name="<%= participant.first_name %> <%= participant.last_name %>">
						<svg class="text-red-600" aria-hidden="true" width="24" height="24">
							<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#delete' %>"></use>
						</svg>
					</button>
					<% } %>
				</div>
				<% }) %>
			</div>
		</section>

		<section class="mt-6 rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
			<div class="mb-4 flex flex-wrap items-baseline gap-2">
				<h3 class="text-lg font-semibold text-gray-900">Chat</h3>
				<span class="text-[1.1rem] text-gray-500"><%= comments.length %> Nachrichten</span>
			</div>

			<div class="max-h-96 space-y-3 overflow-y-auto rounded-lg border border-gray-100 bg-gray-50 p-3" data-event-comments-list>
				<% if (comments.length > 0) { %> <% comments.forEach((comment) => { %>
				<div class="rounded-lg bg-white p-3 shadow-sm">
					<div class="mb-1 flex items-center justify-between gap-3">
						<p class="text-sm font-medium text-gray-900">
							<%= comment.first_name %> <%= comment.last_name %> <% if (comment.is_admin) { %>
							<span class="ml-2 rounded-full border border-amber-200 bg-amber-50 px-2 py-0.5 text-xs font-semibold text-amber-800"
								>Admin</span
							>
							<% } %> <% if (comment.is_current_user) { %>
							<span class="ml-2 rounded-full bg-emerald-100 px-2 py-0.5 text-xs text-emerald-800">Du</span>
							<% } %>
						</p>
						<div class="flex items-center gap-2">
							<span class="text-xs text-gray-500"
								><%= new Date(comment.created_at).toLocaleString('de-DE', { dateStyle: 'short', timeStyle: 'short' }) %></span
							>
							<% if (event.is_admin && !event.is_expired) { %>
							<button
								type="button"
								class="cursor-pointer rounded-sm border-none bg-red-100 p-1.5"
								aria-label="Nachricht löschen"
								data-event-comment-delete
								data-delete-url="/events/<%= event.id %>/comments/<%= comment.id %>/delete">
								<svg class="text-red-600" aria-hidden="true" width="16" height="16">
									<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#delete' %>"></use>
								</svg>
							</button>
							<% } %>
						</div>
					</div>
					<p class="text-sm whitespace-pre-wrap text-gray-700"><%= comment.content %></p>
				</div>
				<% }) %> <% } else { %>
				<p class="text-sm text-gray-600">Noch keine Nachrichten vorhanden.</p>
				<% } %>
			</div>

			<form method="POST" action="/events/<%= event.id %>/comments" class="mt-4 flex flex-col gap-3">
				<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
				<textarea
					name="content"
					required
					maxlength="2000"
					rows="3"
					placeholder="Nachricht schreiben..."
					class="w-full rounded-lg border border-emerald-200 bg-white px-3 py-2 text-sm text-gray-900 outline-none [--focus-color:var(--color-accent-blue)]"></textarea>
				<button
					type="submit"
					class="w-full cursor-pointer rounded-md bg-emerald-600 px-4 py-3 font-semibold text-white shadow-md shadow-emerald-900/20 transition-colors hover:bg-emerald-700 sm:w-fit">
					Nachricht senden
				</button>
			</form>
		</section>

		<% if (event.is_admin && event.is_expired) { %>
		<p class="mt-4 rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm font-medium text-amber-800">
			Der Termin ist abgelaufen. Du kannst ihn nur noch löschen.
		</p>
		<% } %>

		<div class="mt-6">
			<% if (!event.is_admin) { %> <% if (event.is_participating) { %>
			<form method="POST" action="/events/<%= event.id %>/leave">
				<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
				<button
					type="submit"
					class="w-full cursor-pointer rounded-xl border border-red-100 bg-white px-4 py-3 font-medium text-red-500 transition-all hover:bg-gray-50">
					Nicht teilnehmen
				</button>
			</form>
			<% } else { %>
			<form method="POST" action="/events/<%= event.id %>/join">
				<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
				<button
					type="submit"
					class="w-full cursor-pointer rounded-xl bg-emerald-600 px-4 py-3 font-semibold text-white shadow-md shadow-emerald-900/20 transition-colors hover:bg-emerald-700">
					Teilnehmen
				</button>
			</form>
			<% } %> <% } else { %>
			<button
				type="button"
				class="btn-delete-event w-full cursor-pointer rounded-xl border border-red-100 bg-white px-4 py-3 font-medium text-red-500 transition-all hover:bg-gray-50"
				data-event-delete-url="/events/<%= event.id %>/delete"
				data-event-title="<%= event.title %>">
				Termin löschen
			</button>
			<% } %>
		</div>
	</div>
</main>

<%- include("../parts/footer") %>
