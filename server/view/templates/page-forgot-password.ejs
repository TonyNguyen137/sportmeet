<%- include("../parts/header") %>

<main class="grid grid-cols-[minmax(300px,550px)] place-content-center p-[16px] py-[32px]">
	<div class="login rounded-default bg-white p-[16px] text-center sm:p-[32px]">
		<div class="bg-accent-blue mx-auto mb-4 flex h-[64px] w-[64px] items-center justify-center rounded-full">
			<svg width="32" height="32" aria-hidden="true" class="text-white">
				<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#user' %>"></use>
			</svg>
		</div>
		<h1 class="text-h1 leading-none font-bold text-black">Passwort zurücksetzen</h1>
		<p class="mt-4">Geben Sie Ihre E-Mail-Adresse ein, um Ihr Passwort zurückzusetzen</p>
		<form data-forgot-password-form class="login__form text-neutral mt-5 text-start" action="/forgot-password" method="POST">
			<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
			<div
				class="<%= forgotSuccessMessage ? 'block' : 'hidden' %> mt-4 mb-6 rounded-lg border border-emerald-200 bg-emerald-50 p-3"
				tabindex="-1">
				<p class="text-sm font-semibold text-emerald-800"><%= forgotSuccessMessage %></p>
			</div>
			<div
				class="<%= forgotErrors && forgotErrors.length ? 'block' : 'hidden' %> mt-4 mb-6 rounded-lg border border-amber-200 bg-amber-50 p-3"
				data-error-container
				tabindex="-1">
				<p class="text-sm font-semibold text-amber-800" data-error-title>
					<%= forgotErrorTitle || 'Fehlende Angaben, bitte füllen Sie die gelisteten Felder aus:' %>
				</p>
				<ul class="mt-2 list-disc ps-[0.85em]" data-error-list>
					<% if (forgotErrors && forgotErrors.length) { %> <% forgotErrors.forEach((error) => { %>
					<li class="text-sm text-amber-700"><%= error %></li>
					<% }) %> <% } %>
				</ul>
			</div>
			<div class="login__group">
				<label class="text-sm text-black" for="email">E-Mail-Adresse</label>
				<div
					class="focus-within:outline-accent-blue mt-1 flex items-center gap-[12px] rounded-sm px-[16px] py-[12px] outline outline-neutral-100 focus-within:outline focus-within:outline-[2px]">
					<svg class="text-neutral-400" width="20" height="20" aria-hidden="true">
						<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#email' %>"></use>
					</svg>

					<input
						class="grow placeholder:text-neutral-400 focus-visible:outline-0"
						type="email"
						id="email"
						name="email"
						data-field-label="E-Mail-Adresse"
						value="<%= (forgotValues && forgotValues.email) || '' %>"
						placeholder="ihre@email.com"
						required />
				</div>
			</div>

			<button
				type="submit"
				class="bg-accent-blue hover:bg-accent-dark-blue mt-4 w-full cursor-pointer rounded-sm p-[12px] text-white transition-colors duration-200 ease-in-out focus-within:[--focus-color:var(--color-focus-ring-light)]">
				Link zum Zurücksetzen senden
			</button>
			<a href="/" class="text-accent-blue mt-4 inline-block text-center hover:underline">Zurück zur Anmeldung</a>
		</form>
	</div>
</main>

<%- include("../parts/footer") %>
