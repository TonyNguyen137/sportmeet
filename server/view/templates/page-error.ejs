<%- include("../parts/header") %>

<main class="container mx-auto max-w-3xl px-4 py-10 text-start">
	<section class="rounded-lg border border-red-200 bg-red-50 p-6 md:p-8">
		<p class="text-sm font-semibold tracking-wide text-red-700 uppercase"><%= errorStatusCode || 500 %></p>
		<h1 class="mt-1 text-2xl font-bold text-red-900">Ein Fehler ist aufgetreten</h1>
		<p class="mt-3 text-red-800"><%= errorMessage || 'Bitte versuchen Sie es später erneut.' %></p>
	</section>
</main>

