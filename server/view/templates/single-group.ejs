<%- include("../parts/header", { variant: "user" }) %>

<main>
	<div class="container mx-auto px-[12px] py-[32px]">
		<a
			href="/me/groups"
			class="text-accent-blue hover:text-accent-dark-blue mb-4 inline-flex cursor-pointer items-center gap-2 text-sm font-semibold">
			<span aria-hidden="true"><-</span>
			zurück
		</a>
		<div class="overflow-auto rounded-sm bg-white shadow-sm">
			<div class="bg-accent-blue p-4 text-white md:px-8 md:py-5">
				<h1 class="text-h1 font-bold"><%= group.name %></h1>
				<p><%= group.member_count %> Mitglieder</p>
			</div>

			<div class="p-4 md:px-8 md:py-5">
				<% if (group.description) { %>
				<div class="flex items-start gap-2">
					<span class="bg-secondary rounded-sm p-1">
						<svg class="text-accent-blue" aria-hidden="true" width="24" height="24" aria-hidden="true">
							<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#text-quote' %>"></use>
						</svg>
					</span>

					<div>
						<p class="text-sm text-gray-500">Beschreibung</p>
						<p class="text-gray-900"><%= group.description %></p>
					</div>
				</div>
				<% } %>

				<div class="mt-4 flex items-start gap-2">
					<span class="bg-secondary rounded-sm p-1">
						<svg class="text-accent-blue" aria-hidden="true" width="24" height="24" aria-hidden="true">
							<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#admin' %>"></use>
						</svg>
					</span>

					<div>
						<p class="text-sm text-gray-500">Administrator</p>
						<p class="font-medium text-gray-900">
							<%= group.admin_first_name %> <%= group.admin_last_name %> <% if (group.is_owner) { %>
							<span class="ml-2 rounded-full bg-blue-100 px-2 py-0.5 text-xs text-blue-800">Du</span>
							<% } %>
						</p>
					</div>
				</div>
			</div>
		</div>

		<section class="mt-6 rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
			<div class="mb-4 flex flex-wrap items-baseline gap-2">
				<h3 class="text-lg font-semibold text-gray-900">Mitglieder</h3>
				<span class="text-[1.1rem] text-gray-500"><%= group.member_count %></span>
			</div>
			<div class="max-h-96 space-y-3 overflow-y-auto" data-group-members-list>
				<% members.forEach((member) => { %> <% const initials = `${(member.first_name || '').charAt(0)}${(member.last_name ||
				'').charAt(0)}`.toUpperCase(); %>
				<div class="flex items-center gap-3 rounded-lg bg-gray-50 p-3 transition-colors hover:bg-gray-100">
					<div
						class="flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-blue-400 to-purple-500 text-sm font-semibold text-white">
						<%= initials %>
					</div>
					<div class="min-w-0 flex-1">
						<p class="truncate text-sm font-medium text-gray-900">
							<%= member.first_name %> <%= member.last_name %> <% if (member.is_current_user) { %>
							<span class="ml-2 rounded-full bg-blue-100 px-2 py-0.5 text-xs text-blue-800">Du</span>
							<% } %>
						</p>
						<% if (member.role === 'admin') { %>
						<span
							class="inline-flex items-center rounded-full border border-amber-200 bg-amber-50 px-2 py-0.5 text-xs font-semibold text-amber-800">
							Admin
						</span>
						<% } else { %>
						<p class="text-xs text-gray-500">Mitglied</p>
						<% } %>
					</div>
					<% if (group.is_owner && member.role !== 'admin') { %>
					<button
						type="button"
						class="cursor-pointer rounded-sm border-none bg-red-100 p-2"
						aria-label="Mitglied entfernen"
						data-group-member-kick
						data-kick-url="/groups/<%= group.id %>/members/<%= member.id %>/remove"
						data-member-name="<%= member.first_name %> <%= member.last_name %>">
						<svg class="text-red-600" aria-hidden="true" width="24" height="24">
							<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#delete' %>"></use>
						</svg>
					</button>
					<% } %>
				</div>
				<% }) %>
			</div>
		</section>

		<section class="mt-6 rounded-xl bg-white p-6 shadow-sm">
			<div class="flex flex-wrap items-baseline gap-4">
				<h2 class="text-2xl font-bold text-gray-900">Kommende Termine</h2>
				<span class="text-sm text-[1.1rem] text-gray-500"><%= upcomingEvents.length %> Termine</span>
			</div>
			<% if (upcomingEvents.length > 0) { %>
			<div class="mt-4 grid w-full grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
				<% upcomingEvents.forEach((event) => { %>
				<a
					href="/events/<%= event.id %>"
					class="block rounded-xl border border-blue-100 bg-gradient-to-br from-white to-blue-50 p-5 shadow-sm transition-all [--focus-color:var(--color-accent-blue)] hover:to-blue-100 hover:shadow-md focus:outline-none">
					<div class="mb-3 flex items-start justify-between">
						<div class="flex-1">
							<h3 class="text-lg font-semibold text-gray-900"><%= event.title %></h3>
							<% if (event.is_created_by_current_user) { %>
							<span class="mt-1 inline-flex items-center rounded-full bg-yellow-50 px-2 py-1 text-xs font-medium text-yellow-700"
								>Von dir erstellt</span
							>
							<% } %>
						</div>
						<% if (event.current_user_status === 'accepted') { %>
						<span class="rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-700">Zugesagt</span>
						<% } else if (event.current_user_status === 'declined') { %>
						<span class="rounded-full bg-red-100 px-3 py-1 text-xs font-medium text-red-700">Abgesagt</span>
						<% } %>
					</div>

					<div class="mb-4 space-y-2 text-sm text-gray-600">
						<div class="flex items-center gap-2">
							<svg aria-hidden="true" width="16" height="16" class="text-gray-400">
								<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#calendar' %>"></use>
							</svg>
							<span><%= new Date(event.start_datetime).toLocaleString('de-DE', { dateStyle: 'short', timeStyle: 'short' }) %> Uhr</span>
						</div>
						<div class="flex items-center gap-2">
							<svg aria-hidden="true" width="16" height="16" class="text-gray-400">
								<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#globe' %>"></use>
							</svg>
							<span> <%= event.location_name || `${event.street} ${event.house_number}, ${event.postal_code} ${event.city}` %> </span>
						</div>
						<div class="flex items-center gap-2">
							<svg aria-hidden="true" width="16" height="16" class="text-gray-400">
								<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#group' %>"></use>
							</svg>
							<span><%= event.accepted_count %> Teilnehmer zugesagt</span>
						</div>
					</div>

					<div class="flex items-center justify-between border-t border-gray-100 pt-3">
						<span class="text-xs text-gray-600"
							>Erstellt von <span class="font-semibold text-gray-900"><%= event.creator_name %></span></span
						>
						<span class="text-xs text-gray-500"><%= event.sport_name %></span>
					</div>
				</a>
				<% }) %>
			</div>
			<% } else { %>
			<div class="mt-4 rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm text-gray-600">Es gibt momentan keine Termine.</div>
			<% } %>
		</section>

		<% if (group.is_owner) { %>
		<button
			type="button"
			class="btn-delete-group mt-4 flex w-full cursor-pointer items-center justify-center gap-3 rounded-xl border border-red-100 bg-white px-4 py-3 font-medium text-red-500 transition-all hover:bg-gray-50 hover:bg-gray-100"
			data-group-delete-url="/groups/<%= group.id %>/delete"
			data-group-name="<%= group.name %>">
			Gruppe löschen

			<span class="border-nonep-2 rounded-sm">
				<svg class="text-red-600" aria-hidden="true" width="24" height="24" aria-hidden="true">
					<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#trash' %>"></use>
				</svg>
			</span>
		</button>
		<% } %>
	</div>
</main>

<%- include("../parts/footer") %>
