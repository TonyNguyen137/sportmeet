<div class="grid w-full grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
	<% groups.forEach((group) => { %>
	<div
		class="from-secondary to-primary rounded-default flex h-full flex-col border bg-linear-to-br p-5 shadow-sm transition-transform duration-200 hover:-translate-y-0.5 hover:shadow-md hover:ring-2 hover:ring-blue-200">
		<div class="flex items-start justify-between gap-3">
			<div class="min-w-0">
				<div class="mb-1 flex items-center gap-2">
					<p class="text-dark text-md truncate leading-[1.1] font-bold"><%= group.name %></p>
				</div>
				<p class="text-xsm text-body mt-1">Mitglieder: <%= group.member_count %></p>
			</div>
			<span class="bg-light text-accent-dark-blue text-xsm inline-flex rounded-full px-3 py-1 font-semibold uppercase">
				<%= group.role %>
			</span>
		</div>

		<div class="mt-4 space-y-3">
			<% if (group.role === 'admin') { %>
			<div class="rounded-md border border-blue-100 bg-white/80 p-3">
				<div class="flex flex-wrap items-center justify-between">
					<p class="text-xsm text-body font-semibold">Einladungscode</p>

					<div class="flex items-center gap-2">
						<button
							type="button"
							data-copy-button
							data-copy-text="<%= group.invite_code %>"
							class="text-accent-blue hover:bg-light inline-flex cursor-pointer items-center justify-center rounded-md border border-blue-200 p-1 transition-colors"
							aria-label="Einladungscode kopieren">
							<svg data-copy-icon-default width="16" height="16" aria-hidden="true">
								<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#copy' %>"></use>
							</svg>
							<svg data-copy-icon-success width="16" height="16" aria-hidden="true" class="hidden text-emerald-600">
								<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#check' %>"></use>
							</svg>
						</button>
					</div>
				</div>
				<div class="mt-1 flex items-center justify-between gap-2">
					<p class="text-dark font-mono text-sm tracking-wide"><%= group.invite_code %></p>
				</div>
			</div>

			<div class="rounded-md border border-blue-100 bg-white/80 p-3">
				<div class="flex flex-wrap items-center justify-between">
					<p class="text-xsm text-body font-semibold">Einladungslink</p>

					<div class="flex items-center gap-2">
						<button
							type="button"
							data-copy-button
							data-copy-text="<%= group.invite_link %>"
							class="text-accent-blue hover:bg-light inline-flex cursor-pointer items-center justify-center rounded-md border border-blue-200 p-1 transition-colors"
							aria-label="Einladungscode kopieren">
							<svg data-copy-icon-default width="16" height="16" aria-hidden="true">
								<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#copy' %>"></use>
							</svg>
							<svg data-copy-icon-success width="16" height="16" aria-hidden="true" class="hidden text-emerald-600">
								<use href="<%= publicPrefix + '/' + assets['sprite.svg'] + '#check' %>"></use>
							</svg>
						</button>
					</div>
				</div>
				<p class="text-dark text-xsm mt-1 leading-relaxed break-all"><%= group.invite_link %></p>
			</div>

			<form method="POST" action="/groups/<%= group.id %>/regenerate-invite" class="mt-3">
				<input type="hidden" name="_csrf" value="<%= csrfToken %>" />
				<button
					type="submit"
					class="cursor-pointer rounded-sm border border-amber-200 bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-800 transition-colors hover:bg-amber-100">
					Einladungslink neu generieren
				</button>
			</form>
			<% } %>

			<a
				href="/groups/<%= group.id %>"
				class="text-accent-dark-blue text-xsm mt-2 inline-flex w-fit items-center gap-1 font-semibold underline-offset-2 [--focus-color:var(--color-body)] hover:underline">
				Gruppe öffnen
				<span aria-hidden="true">-></span>
			</a>
		</div>
	</div>
	<% }) %>
</div>
